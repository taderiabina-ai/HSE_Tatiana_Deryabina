# Данные истца (замените на свои реальные данные перед сдачей)
PLAINTIFF_DATA = {
    "name": "Пупкин Василий Геннадьевич",
    "inn": "1236182357",
    "ogrnip": "218431927812733",
    "address": "123534, г. Москва, ул. Водников, 13"
}


def generate_court_header(defendant: dict, case_number: str) -> str:
    """
    Генерирует шапку процессуального документа.
    
    Args:
        defendant: словарь с данными ответчика
        case_number: номер дела (например, 'А40-123456/2023')
        
    Returns:
        Готовая шапка в виде строки
    """
    # Извлекаем код суда до первого дефиса
    court_code = case_number.split("-")[0]
    
    # Получаем данные суда из справочника
    court_info = courts.get(court_code)
    if not court_info:
        return f"⚠️ Суд с кодом {court_code} не найден в справочнике."
        
    court_name = court_info["court_name"]
    court_address = court_info["court_address"]
    
    # Извлекаем данные ответчика с безопасным получением значений
    def_name = defendant.get("short_name", defendant.get("full_name", "Не указано"))
    def_inn = defendant.get("inn", "Не указан")
    def_ogrn = defendant.get("ogrn", "Не указан")
    def_address = defendant.get("address", "Не указан")
    
    # Формируем шапку с помощью f-string в точности по шаблону
    header = (
        f"В {court_name}\n"
        f"Адрес: {court_address}\n"
        f"Истец: {PLAINTIFF_DATA['name']} ИНН {PLAINTIFF_DATA['inn']} "
        f"ОГРНИП {PLAINTIFF_DATA['ogrnip']} Адрес: {PLAINTIFF_DATA['address']}\n"
        f"Ответчик: {def_name} ИНН {def_inn} ОГРН {def_ogrn} "
        f"Адрес: {def_address}\n"
        f"Номер дела {case_number}"
    )
    return header


# =============================================================================
# 3. Функция массовой генерации шапок
# =============================================================================

def generate_multiple_headers(respondents_list: list) -> None:
    """
    Принимает список словарей с данными ответчиков.
    Использует цикл for для генерации и вывода всех шапок в консоль.
    """
    for idx, respondent in enumerate(respondents_list, start=1):
        case_num = respondent.get("case_number")
        if case_num:
            print(f"--- Документ #{idx} ---")
            print(generate_court_header(respondent, case_num))
            print("\n" + "=" * 60 + "\n")


