def factorial(n: int) -> int:
    """Вычисляет факториал числа n (произведение натуральных чисел от 1 до n)."""
    if n < 0:
        raise ValueError("Факториал не определён для отрицательных чисел")
    result = 1
    for i in range(2, n + 1):
        result *= i
    return result


def find_max_of_three(numbers: tuple) -> float:
    """Находит наибольшее число из трёх переданных в кортеже."""
    if len(numbers) != 3:
        raise ValueError("Функция ожидает кортеж ровно из трёх чисел")
    return max(numbers)


def right_triangle_area(leg1: float, leg2: float) -> float:
    """Рассчитывает площадь прямоугольного треугольника по двум катетам."""
    if leg1 <= 0 or leg2 <= 0:
        raise ValueError("Длины катетов должны быть положительными")
    return 0.5 * leg1 * leg2


